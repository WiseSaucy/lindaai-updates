# LindaAI Telegram Bridge config
# Copy to ~/.claude/lindaai/telegram.env and fill in.

# From @BotFather after you create your bot:
TELEGRAM_BOT_TOKEN=paste-token-here

# Your personal Telegram user ID (message the bot once, then use /whoami in Telegram).
# Locks the bot to only respond to YOU. Leave blank to allow anyone (not recommended).
TELEGRAM_ALLOWED_USER_ID=
