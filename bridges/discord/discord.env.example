# LindaAI Discord Bridge config
# Copy to ~/.claude/lindaai/discord.env and fill in.

# From discord.com/developers → your app → Bot → Reset Token:
DISCORD_BOT_TOKEN=paste-token-here

# Your Discord user ID. Right-click your own avatar in Discord → "Copy User ID".
# Leave blank to allow anyone (not recommended).
DISCORD_ALLOWED_USER_ID=
